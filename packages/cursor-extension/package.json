{
  "name": "citebridge-cursor",
  "displayName": "CiteBridge for Cursor",
  "description": "Drag Zotero papers into LaTeX documents and automatically maintain BibTeX references.",
  "version": "0.1.4",
  "publisher": "citebridge",
  "type": "module",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Other"],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage:latex",
    "onCommand:citebridge.initializeProject",
    "onCommand:citebridge.refreshLibrary",
    "onCommand:citebridge.importFromInbox",
    "onCommand:citebridge.activateProject",
    "onCommand:citebridge.deactivateProject",
    "onCommand:citebridge.insertCitation",
    "onUri"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p ../shared/tsconfig.json && tsc -p tsconfig.json --noEmit",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.32.0",
    "typescript": "^5.5.4"
  },
  "contributes": {
    "commands": [
      {
        "command": "citebridge.initializeProject",
        "title": "CiteBridge: Initialize LaTeX Project"
      },
      {
        "command": "citebridge.refreshLibrary",
        "title": "CiteBridge: Refresh Library"
      },
      {
        "command": "citebridge.importFromInbox",
        "title": "CiteBridge: Import from Inbox"
      },
      {
        "command": "citebridge.activateProject",
        "title": "CiteBridge: Activate Project",
        "icon": "$(radio-tower)"
      },
      {
        "command": "citebridge.deactivateProject",
        "title": "CiteBridge: Deactivate Project",
        "icon": "$(circle-slash)"
      },
      {
        "command": "citebridge.insertCitation",
        "title": "CiteBridge: Insert Citation"
      },
      {
        "command": "citebridge.openPaperPdf",
        "title": "CiteBridge: Open Paper PDF"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "citebridge.activateProject",
          "when": "view == citebridge.libraryView && !citebridge.projectActive",
          "group": "navigation"
        },
        {
          "command": "citebridge.deactivateProject",
          "when": "view == citebridge.libraryView && citebridge.projectActive",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "citebridge.insertCitation",
          "when": "view == citebridge.libraryView && viewItem == citebridge.paper",
          "group": "inline"
        },
        {
          "command": "citebridge.openPaperPdf",
          "when": "view == citebridge.libraryView && viewItem == citebridge.paper"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "citebridge",
          "title": "CiteBridge",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "citebridge": [
        {
          "id": "citebridge.libraryView",
          "name": "Papers"
        }
      ]
    },
    "configuration": {
      "title": "CiteBridge",
      "properties": {
        "citebridge.defaultBibFile": {
          "type": "string",
          "default": "refs.bib"
        },
        "citebridge.defaultPapersDir": {
          "type": "string",
          "default": "papers"
        },
        "citebridge.defaultCiteCommand": {
          "type": "string",
          "default": "citep",
          "enum": ["citep", "citet", "cite", "parencite", "textcite"]
        },
        "citebridge.copyPdf": {
          "type": "boolean",
          "default": true
        },
        "citebridge.zoteroLocalApiBaseUrl": {
          "type": "string",
          "default": "http://localhost:23119/api"
        }
      }
    }
  }
}
